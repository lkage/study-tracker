{
  "name": "study-tracker-backend",
  "version": "0.1.0",
  "description": "Study time tracker backend",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit",
    "lint": "eslint src/",
    "migrate": "node-pg-migrate -j sql -m migrations",
    "migrate:up": "node-pg-migrate -j sql -m migrations up",
    "migrate:down": "node-pg-migrate -j sql -m migrations down"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "node-pg-migrate": "^7.0.0",
    "pg": "^8.13.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {}
  }
}
